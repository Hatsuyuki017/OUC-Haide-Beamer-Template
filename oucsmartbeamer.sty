%----------------------------------------------------------------------------------------
%   LST LINE-COUNT CHECKER
%   Warn (and recommend a frame break) when an lstlisting exceeds 20 lines.
%   Auto-page-splitting inside a single \begin{lstlisting}...\end{lstlisting}
%   is not safely supported by listings within beamer's fragile-frame
%   capture machinery. The pragmatic recipe is:
%     \begin{frame}[fragile,allowframebreaks]
%       \begin{lstlisting}[language=Python] ... \end{lstlisting}
%     \end{frame}
%   With `allowframebreaks` set, beamer will automatically continue the
%   listing onto a new slide. The checker below prints a build-time warning
%   if a listing exceeds 20 lines so users can add `allowframebreaks`.
\newcounter{ouc@lstmax}\setcounter{ouc@lstmax}{20}
\newcommand{\OUCSetLstMaxLines}[1]{\setcounter{ouc@lstmax}{#1}}
\AtEndEnvironment{lstlisting}{%
    \ifnum\value{lstnumber}>\value{ouc@lstmax}\relax
        \PackageWarning{oucsmartbeamer}{%
            lstlisting on page \thepage\space has \the\value{lstnumber}\space
            lines (limit=\the\value{ouc@lstmax}).\MessageBreak
            Add [allowframebreaks] to the enclosing frame so it auto-paginates%
        }%
    \fi
}

