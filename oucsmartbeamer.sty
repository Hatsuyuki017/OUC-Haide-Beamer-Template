\newcommand{\OUCTitleFrame}{%
    \begin{frame}[plain]
        \begin{tikzpicture}[remember picture,overlay]
            \fill[white] (current page.south west) rectangle (current page.north east);
            \fill[primary]
                (current page.south west) rectangle ([xshift=4.2cm]current page.north west);
            \fill[secondary,opacity=0.85]
                ([xshift=4.2cm]current page.south west) --
                ([xshift=4.2cm]current page.north west) --
                ([xshift=5.0cm]current page.north west) --
                ([xshift=4.6cm]current page.south west) -- cycle;
            \fill[accent,opacity=0.55]
                ([xshift=5.0cm]current page.south west) --
                ([xshift=5.0cm]current page.north west) --
                ([xshift=5.4cm]current page.north west) --
                ([xshift=5.2cm]current page.south west) -- cycle;
