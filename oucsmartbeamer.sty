%% --- Palette system ---------------------------------------------------------
%% Ten palettes (0 = OUC Default, 1-9 = supplied schemes). Within each palette
%% the six colors oucpal1..oucpal6 are sorted by perceived luminance:
%%   pal1 = lightest, ... , pal6 = darkest.
%% Slot usage (see semantic mapping below):
%%   pal1 -> lstlisting background
%%   pal2 -> Example / Remark body + Intro / RightIntro body background
%%   pal3 -> reserved (filled with a duplicate when the source palette only
%%           provides five distinct colors; never used by the semantic mapping)
%%   pal4 -> Example / Remark / Intro title background (mid-dark)
%%   pal5 -> primary / emphasis color (SECOND darkest; titles, frametitle,
%%           footer, theorem titles, block titles)
%%   pal6 -> darkest swatch (unused by the semantic mapping; available
%%           for ad-hoc use such as \color{oucpal6})
\newcommand{\OUCPaletteName}{OUC Default}
\newcommand{\OUCSetPalette}[1]{%
    \ifcase\numexpr#1\relax
        % 0: OUC Default (light->dark)
        \gdef\OUCPaletteName{OUC Default}%
        \definecolor{oucpal1}{RGB}{239,246,255}%
        \definecolor{oucpal2}{RGB}{219,234,254}%
        \definecolor{oucpal3}{RGB}{96,165,250}%
        \definecolor{oucpal4}{RGB}{37,99,235}%
        \definecolor{oucpal5}{RGB}{30,58,138}%
        \definecolor{oucpal6}{RGB}{30,41,59}%
    \or % 1: Brunneophobia (5 distinct; dup -> pal3)
        \gdef\OUCPaletteName{Brunneophobia}%
        \definecolor{oucpal1}{RGB}{238,211,180}%
        \definecolor{oucpal2}{RGB}{213,148,79}%
        \definecolor{oucpal3}{RGB}{213,148,79}%
        \definecolor{oucpal4}{RGB}{180,69,15}%
        \definecolor{oucpal5}{RGB}{86,67,53}%
        \definecolor{oucpal6}{RGB}{42,23,14}%
    \or % 2: Van Dyke (5 distinct; dup -> pal3)
        \gdef\OUCPaletteName{Van Dyke}%
        \definecolor{oucpal1}{RGB}{236,194,188}%
        \definecolor{oucpal2}{RGB}{169,159,191}%
        \definecolor{oucpal3}{RGB}{169,159,191}%
        \definecolor{oucpal4}{RGB}{191,113,133}%
        \definecolor{oucpal5}{RGB}{68,60,94}%
        \definecolor{oucpal6}{RGB}{61,43,39}%
    \or % 3: Back in Black (5 distinct; dup -> pal3)
        \gdef\OUCPaletteName{Back in Black}%
        \definecolor{oucpal1}{RGB}{240,217,228}%
        \definecolor{oucpal2}{RGB}{193,160,172}%
        \definecolor{oucpal3}{RGB}{193,160,172}%
        \definecolor{oucpal4}{RGB}{128,108,121}%
        \definecolor{oucpal5}{RGB}{74,63,75}%
        \definecolor{oucpal6}{RGB}{22,19,21}%
    \or % 4: Belle of the Ball (6 distinct)
        \gdef\OUCPaletteName{Belle of the Ball}%
        \definecolor{oucpal1}{RGB}{226,203,192}%
        \definecolor{oucpal2}{RGB}{206,171,150}%
        \definecolor{oucpal3}{RGB}{210,135,106}%
        \definecolor{oucpal4}{RGB}{229,74,57}%
        \definecolor{oucpal5}{RGB}{118,118,44}%
        \definecolor{oucpal6}{RGB}{53,77,4}%
    \or % 5: Pine Tree (5 distinct; dup -> pal3)
        \gdef\OUCPaletteName{Pine Tree}%
        \definecolor{oucpal1}{RGB}{238,200,111}%
        \definecolor{oucpal2}{RGB}{222,166,32}%
        \definecolor{oucpal3}{RGB}{222,166,32}%
        \definecolor{oucpal4}{RGB}{177,120,133}%
        \definecolor{oucpal5}{RGB}{167,88,26}%
        \definecolor{oucpal6}{RGB}{43,47,34}%
    \or % 6: Provence Blue (5 distinct; dup -> pal3)
        \gdef\OUCPaletteName{Provence Blue}%
        \definecolor{oucpal1}{RGB}{170,188,175}%
        \definecolor{oucpal2}{RGB}{137,156,154}%
        \definecolor{oucpal3}{RGB}{137,156,154}%
        \definecolor{oucpal4}{RGB}{110,124,139}%
        \definecolor{oucpal5}{RGB}{82,92,121}%
        \definecolor{oucpal6}{RGB}{53,66,94}%
    \or % 7: Fresco Blue (5 distinct; dup -> pal3)
        \gdef\OUCPaletteName{Fresco Blue}%
        \definecolor{oucpal1}{RGB}{166,224,244}%
        \definecolor{oucpal2}{RGB}{71,169,207}%
        \definecolor{oucpal3}{RGB}{71,169,207}%
        \definecolor{oucpal4}{RGB}{9,121,158}%
        \definecolor{oucpal5}{RGB}{4,75,102}%
        \definecolor{oucpal6}{RGB}{2,31,46}%
    \or % 8: Monet (5 distinct; dup -> pal3)
        \gdef\OUCPaletteName{Monet}%
        \definecolor{oucpal1}{RGB}{247,244,213}%
        \definecolor{oucpal2}{RGB}{211,150,140}%
        \definecolor{oucpal3}{RGB}{211,150,140}%
        \definecolor{oucpal4}{RGB}{131,153,88}%
        \definecolor{oucpal5}{RGB}{16,86,102}%
        \definecolor{oucpal6}{RGB}{10,51,35}%
    \or % 9: Narcissus (5 distinct; dup -> pal3)
        \gdef\OUCPaletteName{Narcissus}%
        \definecolor{oucpal1}{RGB}{221,213,200}%
        \definecolor{oucpal2}{RGB}{185,149,144}%
        \definecolor{oucpal3}{RGB}{185,149,144}%
        \definecolor{oucpal4}{RGB}{199,149,72}%
        \definecolor{oucpal5}{RGB}{190,108,26}%
        \definecolor{oucpal6}{RGB}{110,60,31}%
    \fi
    %% Semantic mapping (light->dark):
    %%   primary  = pal5 (SECOND darkest; emphasis color used for title,
    %%              frametitle, footer accent, theorem titles, block titles)
    %%   secondary= pal4 (Example/Remark/Intro title background; mid-dark)
    %%   accent   = pal3 (mid-tone; itemize subitem, decorative strips)
    %%   softblue = pal2 (Example/Remark/Intro body background)
    %%   paleblue = pal1 (lstlisting background; lightest)
    \colorlet{primary}{oucpal5}%
    \colorlet{secondary}{oucpal4}%
    \colorlet{accent}{oucpal3}%
    \colorlet{softblue}{oucpal2}%
    \colorlet{paleblue}{oucpal1}%
    %% Listing-private hooks must be re-bound on every palette switch,
    %% otherwise \colorlet snapshots the palette-0 values at package load.
    \colorlet{lstfg}{inkdark}%
    \colorlet{lstbg}{oucpal1}%
    \colorlet{lstaccent}{oucpal6}%
    \colorlet{lstborder}{oucpal6}%
}

