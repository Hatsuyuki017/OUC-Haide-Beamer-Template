%% Proof environment.
%%
%% NOTE: We deliberately bypass `\declaretheorem` here. Beamer wraps every
%% amsthm-style theorem environment in its own `block' template, which would
%% add a coloured title bar on top — completely unlike the book template's
%% inline "Proof.\hspace{.5cm}" + trailing QED layout. The hand-written form
%% below reproduces book's SettingProof byte-for-byte visually:
%%   headfont      = \normalfont\bfseries
%%   bodyfont      = \normalfont
%%   postheadspace = .5cm   (gap between "Proof" and body)
%%   qed           = $\square$ (right-aligned at end)
%%   headpunct     = \;
%%   spaceabove    = spacebelow = 8pt
\providecommand{\OUCQEDsymbol}{\ensuremath{\square}}
\newenvironment{OUCProof}{%
    \par\addvspace{8pt}%
    \noindent{\ouctitledisplay\bfseries\ProofName}{\;}\hspace{.5cm}%
    \normalfont\ignorespaces
}{%
    \unskip\nobreak\hfill\OUCQEDsymbol\par\addvspace{8pt}%
}
\let\Proof\OUCProof
\let\endProof\endOUCProof

%% Boxed: rounded grey container — implemented directly via tcolorbox to
%% bypass beamer's block-wrap of \declaretheorem environments.  The visual
%% target is book template's SettingBox (mdframed with backgroundcolor=
%% black!5, white border, large rounded corners).
\newtcolorbox{OUCBoxed}{%
    enhanced,breakable,
    colback=oucpal2,colframe=white,
    boxrule=0pt,arc=15pt,outer arc=15pt,
    left=.2cm,right=.2cm,top=15pt,bottom=5pt,
    before skip=-5pt,after skip=-5pt,
    fontupper=\color{black}\normalfont
}
\let\Boxed\OUCBoxed
\let\endBoxed\endOUCBoxed

%% Intro and RightIntro (chapter introduction boxes)
\newtcolorbox{Intro}[2][]{%
    enhanced,before skip=2mm,after skip=2mm,
    colback=oucpal2,colframe=white,boxrule=0mm,
    attach boxed title to top left={xshift=.5cm,yshift*=1mm-\tcboxedtitleheight},
    varwidth boxed title*=-2cm,
    boxed title style={colback=oucpal4,frame code={%
        \path[fill=tcbcolback!95!black]
            ([yshift=-1mm,xshift=-1mm]frame.north west)
            arc[start angle=0,end angle=180,radius=1mm]
            ([yshift=-1mm,xshift=1mm]frame.north east)
            arc[start angle=180,end angle=0,radius=1mm];
        \path[top color=tcbcolback,middle color=tcbcolback!80,
              bottom color=tcbcolback!40!white]
            ([xshift=-2mm]frame.north west) --
            ([xshift=2mm]frame.north east)
            [rounded corners=1mm] -- ([xshift=1mm,yshift=-1mm]frame.north east)
            -- (frame.south east) -- (frame.south west)
            -- ([xshift=-1mm,yshift=-1mm]frame.north west)
            [sharp corners]-- cycle;},
        interior engine=empty},
    fonttitle={\ouctitledisplay\bfseries\color{primary}},title={#2},#1}
\newtcolorbox{RightIntro}[2][]{%
    enhanced,before skip=2mm,after skip=2mm,
    colback=oucpal2,colframe=white,boxrule=0mm,
    attach boxed title to top right={xshift=-.5cm,yshift*=1mm-\tcboxedtitleheight},
    varwidth boxed title*=2cm,
    boxed title style={colback=oucpal4,frame code={%
        \path[fill=tcbcolback!95!black]
            ([yshift=-1mm,xshift=-1mm]frame.north west)
            arc[start angle=0,end angle=180,radius=1mm]
            ([yshift=-1mm,xshift=1mm]frame.north east)
            arc[start angle=180,end angle=0,radius=1mm];
        \path[top color=tcbcolback,middle color=tcbcolback!90,
              bottom color=tcbcolback!40!white]
            ([xshift=-2mm]frame.north west) --
            ([xshift=2mm]frame.north east)
            [rounded corners=1mm] -- ([xshift=1mm,yshift=-1mm]frame.north east)
            -- (frame.south east) -- (frame.south west)
            -- ([xshift=-1mm,yshift=-1mm]frame.north west)
            [sharp corners]-- cycle;},
        interior engine=empty},
    fonttitle={\ouctitledisplay\bfseries\color{primary}},title={#2},#1}

%% UnderlineBox: text with double underline (book equivalent)
\newcommand{\UnderlineBox}[1]{%
    \begin{tcolorbox}[colback=white,colframe=white,right=10mm,top=0mm,left=2.5mm]
    {#1}\\[-5pt]
    \tikz{\draw (0,0)--(\linewidth-1cm,0); \draw (0,.05)--(\linewidth-1cm,.05);}
    \end{tcolorbox}}

%% Quote: epigraph wrapper
\newcommand{\Quote}[2]{\epigraph{\textit{#1}}{#2}}

%% Minipage: side-by-side helper
\newcommand{\Minipage}[4]{\noindent%
    \begin{minipage}[t][][b]{#1\textwidth}{#2}\end{minipage}\hfill
    \begin{minipage}[t][][b]{#3\textwidth}{#4}\end{minipage}\noindent}

%% EvOdd: beamer has no odd/even pages; fall back to right-side wrapfigure
\BeforeBeginEnvironment{wrapfigure}{\setlength{\intextsep}{2pt}}
\newcommand{\EvOdd}[3]{%
    \noindent\begin{wrapfigure}[#1]{r}{#2}#3\end{wrapfigure}}

%% Eq / EqL: lightweight align wrappers
\newcommand{\Eq}[1]{\begin{align*}#1\end{align*}}
\newcommand{\EqL}[2]{\begin{align}\label{#2}#1\end{align}}
