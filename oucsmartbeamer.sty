\setbeamertemplate{frametitle}{%
    \nointerlineskip%
    \vspace{0.35cm}%
    \begin{beamercolorbox}[wd=\paperwidth,ht=1.05cm,dp=0cm]{frametitle}%
        \begin{tikzpicture}
            \fill[primary] (0,0) rectangle (0.18,1.0);
            \fill[accent]  (0.18,0) rectangle (0.30,1.0);
            \node[anchor=west,inner sep=0,text=primary,font=\ouctitledisplay\OUCFrameTitleFontSizeSpec\bfseries]
                at (0.55,0.55) {\insertframetitle};
            \draw[linegray,line width=0.6pt] (0.55,0.05) -- (\paperwidth-0.6,0.05);
            \draw[secondary,line width=1.2pt] (0.55,0.05) -- (3.5,0.05);
        \end{tikzpicture}%
    \end{beamercolorbox}%
    \vspace{-0.15cm}%
}

\makeatletter
\newdimen\pb@wd
\newdimen\pb@cur
\pb@wd=\paperwidth
\def\pb@bar{%
    \pb@cur=\paperwidth
    \divide\pb@cur by \inserttotalframenumber
    \multiply\pb@cur by \insertframenumber
    \begin{tikzpicture}[remember picture,overlay]
        \fill[linegray]
            ([yshift=0.12cm]current page.south west)
            rectangle ([yshift=0.15cm]current page.south east);
        \fill[primary]
            ([yshift=0.12cm]current page.south west)
            rectangle ([yshift=0.15cm,xshift=\pb@cur]current page.south west);
    \end{tikzpicture}%
}

\setbeamertemplate{footline}{%
    \leavevmode%
    \hbox{%
        \begin{beamercolorbox}[wd=.6\paperwidth,ht=3.0ex,dp=2.4ex,leftskip=1.2em,sep=0pt]{}%
            \raisebox{1.9ex}{{\oucfooterfont\OUCFooterFontSizeSpec\color{primary} \OUCFooterTitle\,\textbar\,\color{inkgray}\OUCFooterSubtitle}}%
        \end{beamercolorbox}%
        \begin{beamercolorbox}[wd=.4\paperwidth,ht=3.0ex,dp=2.4ex,rightskip=1.2em,sep=0pt]{}%
            \raisebox{1.9ex}{\hfill{{\oucfooterfont\OUCFooterFontSizeSpec\color{inkgray} \insertframenumber\,/\,\inserttotalframenumber}}}%
        \end{beamercolorbox}%
    }%
    \pb@bar%
}
\makeatother

