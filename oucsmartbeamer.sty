%----------------------------------------------------------------------------------------
%   LSTLISTING SETTINGS (multi-language)
%   Background uses palette color 1 (oucpal1); semantic color names fg/bg/
%   accent/border are bound to the active palette so the listing styling
%   follows \OUCSetPalette automatically.
%----------------------------------------------------------------------------------------
\RequirePackage{caption}

%% Listing-private semantic colors. We deliberately do NOT reuse the public
%% palette names (accent, softblue, paleblue) here — those are bound to the
%% palette and consumed by frametitle / background / itemize templates. Using
%% \colorlet on them at this point in the file would clobber the palette
%% semantics (e.g. the colored accent strip in the header would change).
%% Instead we bind private names \lstfg / \lstbg / \lstaccent / \lstborder.
\colorlet{lstfg}{inkdark}
\colorlet{lstbg}{oucpal1}
\colorlet{lstaccent}{oucpal6}
\colorlet{lstborder}{oucpal6}

